# ============================================================
# IPA — Intelligent Personal Assistant
# Environment Configuration Template
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Application
APP_ENV=development
APP_SECRET_KEY=change-this-to-a-random-secret-at-least-32-chars-long
BACKEND_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:5173
ALLOWED_HOSTS=localhost,127.0.0.1

# Microsoft Azure AD / Graph API
# Leave blank to run in mock mode (no Azure account required)
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Role assignment — comma-separated email addresses
# Users not in either list default to "employee" role
MANAGER_EMAILS=manager@contoso.com,lead@contoso.com
ADMIN_EMAILS=admin@contoso.com

# OpenAI (optional — for Whisper STT and GPT-4o-mini intent parsing)
OPENAI_API_KEY=

# Feature flags
USE_MOCK_GRAPH=true
USE_MOCK_STT=true
USE_MOCK_TTS=true
USE_LLM_INTENT=false

# Database 
DATABASE_URL=sqlite+aiosqlite:///./ipa.db

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Logging
LOG_LEVEL=INFO